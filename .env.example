# Database Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=your_username
DB_PASSWORD=your_secure_password
DB_NAME=your_database_name

# Alternative database connection (if needed)
DB_HOST_ALT=127.0.0.1
DB_PORT_ALT=3306
DB_USERNAME_ALT=your_alt_username
DB_PASSWORD_ALT=your_alt_secure_password
DB_NAME_ALT=your_alt_database_name

# Application Environment
APP_ENV=development
APP_DEBUG=true

# Contact Form
CONTACT_EMAIL=simsiewe@gmh-sarl.com
